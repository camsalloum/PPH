        <Tag color="blue">PostgreSQL 15+</Tag>
      }
    >
      <Collapse defaultActiveKey={['0', '1']} accordion={false}>
        {DATABASE_TABLES.map((category, idx) => (
          <Panel 
            key={idx}
            header={
              <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
                <span style={{
                  width: '12px',
                  height: '12px',
                  borderRadius: '50%',
                  backgroundColor: category.color,
                }}></span>
                <Text strong>{category.category}</Text>
                <Badge count={category.tables.length} style={{ backgroundColor: category.color }} />
              </div>
            }
          >
            <div style={{ display: 'flex', flexDirection: 'column', gap: '16px' }}>
              {category.tables.map(table => (
                <div 
                  key={table.name}
                  style={{
                    padding: '16px',
                    backgroundColor: '#fafafa',
                    borderRadius: '8px',
                    border: `1px solid ${category.color}30`,
                  }}
                >
                  <div style={{ display: 'flex', alignItems: 'center', gap: '8px', marginBottom: '8px' }}>
                    <DatabaseOutlined style={{ color: category.color }} />
                    <Text strong style={{ fontFamily: 'monospace' }}>{table.name}</Text>
                  </div>
                  <Paragraph type="secondary" style={{ margin: '0 0 12px 0', fontSize: '13px' }}>
                    {table.description}
                  </Paragraph>
                  <div style={{ marginBottom: '8px' }}>
                    <Text type="secondary" style={{ fontSize: '12px' }}>Columns:</Text>
                    <div style={{ display: 'flex', flexWrap: 'wrap', gap: '4px', marginTop: '4px' }}>
                      {table.columns.map(col => (
                        <Tag key={col} color="blue" style={{ fontSize: '11px', fontFamily: 'monospace' }}>
                          {col}
                        </Tag>
                      ))}
                    </div>
                  </div>
                  {table.recordTypes && (
                    <div style={{ marginBottom: '8px' }}>
                      <Text type="secondary" style={{ fontSize: '12px' }}>Record Types:</Text>
                      <div style={{ display: 'flex', gap: '4px', marginTop: '4px' }}>
                        {table.recordTypes.map(type => (
                          <Tag key={type} color="green" style={{ fontSize: '11px' }}>{type}</Tag>
                        ))}
                      </div>
                    </div>
                  )}
                  <div style={{ 
                    backgroundColor: '#fff7e6', 
                    padding: '8px 12px', 
                    borderRadius: '4px',
                    border: '1px solid #ffe58f',
                  }}>
                    <Text style={{ fontSize: '12px' }}>
                      <strong>Usage:</strong> {table.usage}
                    </Text>
                  </div>
                </div>
              ))}
            </div>
          </Panel>
        ))}
      </Collapse>
    </Card>
  </div>
);

// =============================================================================
// COMPONENT: Data Flows (UPDATED WITH ACTUAL CURRENT SYSTEM)
// =============================================================================
const MermaidDiagram = ({ chart, title }) => {
  const containerRef = useRef(null);
  const [isError, setIsError] = useState(false);

  useEffect(() => {
    if (!containerRef.current) return;

    const renderDiagram = async () => {
      try {
        // Load Mermaid dynamically
        const mermaid = (await import('https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs')).default;
        
        mermaid.initialize({ 
          startOnLoad: false,
          theme: 'default',
          flowchart: { 
            useMaxWidth: true,
            htmlLabels: false,
            curve: 'basis'
          }
        });

        const uniqueId = `mermaid-${Math.random().toString(36).substr(2, 9)}`;
        const { svg } = await mermaid.render(uniqueId, chart);
        containerRef.current.innerHTML = svg;
        setIsError(false);
      } catch (error) {
        console.error('Mermaid rendering error:', error);
        setIsError(true);
        containerRef.current.innerHTML = `<div style="padding: 20px; color: #ff4d4f; background: #fff2f0; border: 1px solid #ffccc7; border-radius: 8px;">
          <strong>⚠️ Diagram Rendering Error</strong><br/>
          <small>Please refresh the page or check console for details.</small>
        </div>`;
      }
    };

    renderDiagram();
  }, [chart]);

  if (isError) {
    return (
      <Card title={title} style={{ ...styles.card, borderLeft: '4px solid #ff4d4f' }}>
        <div style={{ padding: '20px', textAlign: 'center' }}>
          <Text type="danger">Failed to render diagram. Please refresh the page.</Text>
        </div>
      </Card>
    );
  }

  return (
    <Card title={title} style={{ ...styles.card, borderLeft: '4px solid #1890ff' }}>
      <div 
        ref={containerRef} 
        style={{ 
          textAlign: 'center', 
          overflow: 'auto',
          maxWidth: '100%',
          wordBreak: 'break-word'
        }} 
      />
    </Card>
  );
};

const DataFlows = () => {
  // Centralized System Overview - Color Coded by Module
  const systemOverviewChart = `
flowchart TB
    subgraph External["EXTERNAL"]
        Oracle[(Oracle)]
        SalesReps([SalesReps])
    end
    
    subgraph ActualFlow["ACTUAL DATA"]
        Excel[Excel]
        Import[Import]
        RawDB[(RawData)]
        Sync[Sync]
        ActualDB[(Actualcommon)]
        ActualUI[ActualTab]
    end
    
    subgraph BudgetFlow["BUDGET DATA"]
        HTMLExp[HTMLExport]
        SREdit[SalesRepEdit]
        HTMLImp[HTMLImport]
        DivEdit[DivisionalEdit]
        UnifiedDB[(BudgetUnified)]
    end
    
    subgraph PricingFlow["PRICING"]
        PricingMV[(PricingMV)]
        Calculate[Calculate]
    end
    
    Oracle -->|Export| Excel
    Excel --> Import
    Import --> RawDB
    RawDB --> Sync
    Sync --> ActualDB
    ActualDB --> ActualUI
    
    ActualUI --> HTMLExp
    HTMLExp --> SalesReps
    SalesReps --> SREdit
    SREdit --> HTMLImp
    HTMLImp --> UnifiedDB
    
    ActualUI --> DivEdit
    DivEdit --> UnifiedDB
    
    ActualDB --> PricingMV
    PricingMV --> Calculate
    Calculate --> DivEdit
    Calculate --> SREdit
    
    UnifiedDB --> ActualUI
    
    style ActualFlow fill:#e6f7ff,stroke:#1890ff,stroke-width:3px
    style BudgetFlow fill:#f6ffed,stroke:#52c41a,stroke-width:3px
    style PricingFlow fill:#fff7e6,stroke:#faad14,stroke-width:3px
    style External fill:#f0f0f0,stroke:#8c8c8c,stroke-width:2px
  `;

  const actualDataFlowChart = `
flowchart TD
    Start([UserSync])
    Oracle[(Oracle)]
    Excel[ExcelFile]
    API[APICall]
    Script[ImportScript]
    Disable{DisableTrigger}
    Batch[BatchINSERT]
    Enable{EnableTrigger}
    Sync[SyncFunction]
    Raw[(RawData)]
    Actual[(Actualcommon)]
    UI[Display]
    
    Oracle --> Excel
    Start --> API
    Excel --> Script
    API --> Script
    Script --> Disable
    Disable --> Batch
    Batch --> Enable
    Enable --> Sync
    Batch --> Raw
    Sync --> Actual
    Actual --> UI
    
    style Oracle fill:#fff4e6
    style Raw fill:#ffebee
    style Actual fill:#e8f5e9
    style UI fill:#e1f5ff
  `;

  const budgetDivisionalChart = `
flowchart TD
    Start([OpenBudget])
    Load[LoadData]
    Check{HasDraft?}
    
    Draft[LoadDRAFT]
    Approved[LoadAPPROVED]
    
    Display[EditTable]
    Save[AutoSave]
    DB[(BudgetUnified)]
    
    Submit([Submit])
    Final[(SetApproved)]
    
    Start --> Load
    Load --> Check
    Check -->|Yes| Draft
    Check -->|No| Approved
    Draft --> Display
    Approved --> Display
    Display --> Save
    Save --> DB
    Display --> Submit
    Submit --> Final
    
    style Draft fill:#e6f7ff
    style Approved fill:#b7eb8f
    style DB fill:#ffd6e7
    style Final fill:#d4edda
  `;

  const budgetSalesRepChart = `
flowchart TD
    Start([ExportHTML])
    Export[GenerateForm]
    HTML[HTMLFile]
    
    Fill([SalesRepFills])
    Draft[SaveDraft]
    Final[SaveFinal]
    
    Upload([ImportHTML])
    Parse[ExtractData]
    DB[(BudgetUnified)]
    
    Start --> Export
    Export --> HTML
    HTML --> Fill
    Fill --> Draft
    Fill --> Final
    Final --> Upload
    Upload --> Parse
    Parse --> DB
    
    style HTML fill:#fff4e6
    style Draft fill:#e6f7ff
    style Final fill:#b7eb8f
    style DB fill:#d4edda
  `;

  const budgetUnifiedChart = `
flowchart LR
    subgraph DB["BudgetUnifiedTable"]
        SR[SalesRep]
        DR[DivDraft]
        DA[DivFinal]
    end
    
    SR --> Agg[SUM]
    DA --> Agg
    Agg --> Reports[Reports]
    
    style SR fill:#b7eb8f
    style DR fill:#ffd6e7
    style DA fill:#d4edda
  `;

  const pricingFlowChart = `
flowchart TD
    Actual[(Actuals)]
    MV[(PricingMV)]
    
    Logic{BudgetYear?}
    Y1[2024-25:SameYear]
    Y2[2026+:YearMinus1]
    
    Calc[CalculateAmount]
    Save[(Store)]
    
    Actual --> MV
    MV --> Logic
    Logic --> Y1
    Logic --> Y2
    Y1 --> Calc
    Y2 --> Calc
    Calc --> Save
    
    style MV fill:#fff3e0
    style Calc fill:#e1f5ff
    style Save fill:#d4edda
  `;

  return (
    <div style={{ padding: '20px' }}>
      <Alert
        message="✅ Updated to Current System Architecture"
        description="These diagrams reflect the actual implementation. The centralized overview shows color-coded modules, detailed flows below show step-by-step processes."
        type="success"
        showIcon
        style={{ marginBottom: '20px', borderRadius: '8px' }}
      />

      <MermaidDiagram 
        title={
          <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
            <ClusterOutlined style={{ color: '#722ed1', fontSize: '20px' }} />
            <span>🎯 CENTRALIZED SYSTEM OVERVIEW - Color Coded by Module</span>
          </div>
        }
        chart={systemOverviewChart}
      />

      <Divider style={{ margin: '32px 0' }}>
        <Text strong style={{ fontSize: '16px' }}>📋 Detailed Process Flows</Text>
      </Divider>

      <MermaidDiagram 
        title={
          <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
            <DatabaseOutlined style={{ color: '#1890ff', fontSize: '20px' }} />
            <span>1. Actual Data Flow - Oracle to UI</span>
          </div>
        }
        chart={actualDataFlowChart}
      />

      <MermaidDiagram 
        title={
          <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
            <EditOutlined style={{ color: '#52c41a', fontSize: '20px' }} />
            <span>2. Budget Flow - Divisional (Live Editing)</span>
          </div>
        }
        chart={budgetDivisionalChart}
      />

      <MermaidDiagram 
        title={
          <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
            <FileExcelOutlined style={{ color: '#52c41a', fontSize: '20px' }} />
            <span>3. Budget Flow - Sales Rep (HTML Export/Import)</span>
          </div>
        }
        chart={budgetSalesRepChart}
      />

      <MermaidDiagram 
        title={
          <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
            <MergeCellsOutlined style={{ color: '#722ed1', fontSize: '20px' }} />
            <span>4. Budget Unified Table - Single Source of Truth</span>
          </div>
        }
        chart={budgetUnifiedChart}
      />

      <MermaidDiagram 
        title={
          <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
            <CalculatorOutlined style={{ color: '#fa8c16', fontSize: '20px' }} />
            <span>5. Product Group Pricing Flow</span>
          </div>
        }
        chart={pricingFlowChart}
      />

      <Card style={{ ...styles.card, borderLeft: '4px solid #13c2c2' }}>
        <Title level={4}>📊 Diagram Best Practices</Title>
        <div style={{ lineHeight: '1.8' }}>
          <Paragraph>
            <Text strong>✅ Centralized Overview (Top):</Text>
            <ul>
              <li><Text strong style={{ color: '#1890ff' }}>Blue:</Text> Actual Data Flow</li>
              <li><Text strong style={{ color: '#52c41a' }}>Green:</Text> Budget Data Flow</li>
              <li><Text strong style={{ color: '#faad14' }}>Orange:</Text> Pricing Flow</li>
              <li>Shows relationships between all modules at a glance</li>
              <li>Great for understanding the big picture</li>
            </ul>
          </Paragraph>
          <Paragraph>
            <Text strong>📋 Detailed Flows (Below):</Text>
            <ul>
              <li>Step-by-step process documentation</li>
              <li>Shows specific APIs, files, and database tables</li>
              <li>Useful for developers implementing changes</li>
              <li>Each flow focuses on one specific process</li>
            </ul>
          </Paragraph>
          <Paragraph>
            <Text strong>💡 Why Both?</Text>
            <ul>
              <li><strong>Managers/Stakeholders:</strong> Use centralized overview for quick understanding</li>
              <li><strong>Developers:</strong> Use detailed flows for implementation</li>
              <li><strong>Training:</strong> Start with overview, drill down into details</li>
              <li><strong>Documentation:</strong> Both perspectives provide complete picture</li>
            </ul>
          </Paragraph>
        </div>
      </Card>

      <Card style={{ ...styles.card, borderLeft: '4px solid #1890ff' }}>
        <Title level={4}>🔑 Key Implementation Notes</Title>
        <div style={{ lineHeight: '1.8' }}>
          <Paragraph>
            <Text strong>Actual Data:</Text>
            <ul>
              <li>Fast import: 1,500 rows/sec (trigger bypass)</li>
              <li>fp_raw_data: UPPERCASE Oracle format</li>
              <li>fp_actualcommon: Proper Case (INITCAP)</li>
            </ul>
          </Paragraph>
          <Paragraph>
            <Text strong>Budget Unified Table:</Text>
            <ul>
              <li><code style={{ whiteSpace: 'pre-wrap', wordBreak: 'break-word' }}>sales_rep_name IS NULL</code> = Divisional</li>
              <li><code style={{ whiteSpace: 'pre-wrap', wordBreak: 'break-word' }}>sales_rep_name = 'Name'</code> = Sales Rep</li>
              <li><code style={{ whiteSpace: 'pre-wrap', wordBreak: 'break-word' }}>status = 'draft'</code> = Work in progress</li>
              <li><code style={{ whiteSpace: 'pre-wrap', wordBreak: 'break-word' }}>status = 'approved'</code> = Finalized</li>
            </ul>
          </Paragraph>
          <Paragraph>
            <Text strong>Pricing Logic:</Text>
            <ul>
              <li>Budget 2024-2025: Uses actual year</li>
              <li>Budget 2026+: Uses (year - 1)</li>
              <li>Materialized view: Daily refresh</li>
            </ul>
          </Paragraph>
        </div>
      </Card>
    </div>
  );
};

