// =============================================================================
// MODULE STATUS DEFINITIONS (for JSX icon-based views)
// =============================================================================
const MODULE_STATUS = {
  IMPLEMENTED: { color: '#52c41a', label: 'Implemented', icon: <CheckCircleOutlined /> },
  IN_PROGRESS: { color: '#1890ff', label: 'In Progress', icon: <SyncOutlined spin /> },
  PLANNED: { color: '#faad14', label: 'Planned', icon: <ClusterOutlined /> },
  FUTURE: { color: '#d9d9d9', label: 'Future', icon: <NodeIndexOutlined /> },
};

// Map ERP_MODULES status to MODULE_STATUS key
const statusToModuleStatus = (status) => {
  switch(status) {
    case 'done': return 'IMPLEMENTED';
    case 'partial': return 'IN_PROGRESS';
    case 'planned': return 'PLANNED';
    default: return 'FUTURE';
  }
};

// Icon mapping for JSX views
const moduleIcons = {
  1: <SafetyCertificateOutlined />, 2: <DashboardOutlined />, 3: <DatabaseOutlined />,
  4: <AimOutlined />, 5: <TeamOutlined />, 6: <PieChartOutlined />,
  7: <FileSearchOutlined />, 8: <FileSearchOutlined />, 9: <DollarOutlined />,
  10: <ShoppingCartOutlined />, 11: <EditOutlined />, 12: <SettingOutlined />,
  13: <SettingOutlined />, 14: <SettingOutlined />, 15: <SettingOutlined />,
  16: <CalculatorOutlined />, 17: <TableOutlined />, 18: <ShoppingCartOutlined />,
  19: <DatabaseOutlined />, 20: <FileExcelOutlined />, 21: <FileSearchOutlined />,
  22: <SyncOutlined />, 23: <CheckCircleOutlined />, 24: <TeamOutlined />,
  25: <DatabaseOutlined />, 26: <GlobalOutlined />, 27: <DollarOutlined />,
  28: <SettingOutlined />, 29: <FileSearchOutlined />, 30: <BarChartOutlined />,
  31: <LineChartOutlined />, 32: <SettingOutlined />,
};

// =============================================================================
// DERIVED: PROJECT_PHASES (Generated from ERP_MODULES for detailed views)
// =============================================================================
const PROJECT_PHASES = PHASES.map(phase => ({
  id: phase.name.toLowerCase().replace(/[^a-z]/g, '-'),
  name: phase.name,
  color: phase.color,
  icon: phase.icon,
  description: `Weeks ${phase.weeks}`,
  modules: ERP_MODULES
    .filter(m => m.phase === phase.id)
    .map(m => ({
      id: m.name.toLowerCase().replace(/[^a-z]/g, '-'),
      name: m.name,
      status: statusToModuleStatus(m.status),
      icon: moduleIcons[m.id] || <SettingOutlined />,
      tables: m.tables || [],
      features: m.features || [],
      apiBase: m.apiBase || '',
      notes: m.notes || '',
    })),
}));

