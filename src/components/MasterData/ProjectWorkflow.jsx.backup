const ModuleArchitecture = () => (
  <div style={{ padding: '20px' }}>
    {PROJECT_PHASES.map(phase => (
      <Card 
        key={phase.id}
        style={{ ...styles.card, borderTop: `4px solid ${phase.color}` }}
      >
        <div style={{
          ...styles.phaseHeader,
          backgroundColor: `${phase.color}10`,
          border: `1px solid ${phase.color}30`,
        }}>
          <span style={{ fontSize: '24px', color: phase.color }}>{phase.icon}</span>
          <div style={{ flex: 1 }}>
            <Title level={4} style={{ margin: 0, color: phase.color }}>
              {phase.name}
            </Title>
            <Text type="secondary">{phase.description}</Text>
          </div>
          <Badge 
            count={`${phase.modules.length} modules`} 
            style={{ backgroundColor: phase.color }}
          />
        </div>

        <div style={{ 
          display: 'grid', 
          gridTemplateColumns: 'repeat(auto-fit, minmax(300px, 1fr))', 
          gap: '16px' 
        }}>
          {phase.modules.map(module => {
            const status = MODULE_STATUS[module.status];
            return (
              <div 
                key={module.id}
                style={{
                  ...styles.moduleCard,
                  borderColor: status.color,
                  backgroundColor: `${status.color}05`,
                }}
              >
                <div style={{ display: 'flex', alignItems: 'flex-start', gap: '12px' }}>
                  <div style={{
                    width: '48px',
                    height: '48px',
                    borderRadius: '12px',
                    backgroundColor: `${status.color}15`,
                    display: 'flex',
                    alignItems: 'center',
                    justifyContent: 'center',
                    color: status.color,
                    fontSize: '20px',
                  }}>
                    {module.icon}
                  </div>
                  <div style={{ flex: 1 }}>
                    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                      <Text strong style={{ fontSize: '14px' }}>{module.name}</Text>
                      <Tag color={status.color} style={{ margin: 0 }}>
                        {status.icon} {status.label}
                      </Tag>
                    </div>
                    <div style={{ marginTop: '8px' }}>
                      <Text type="secondary" style={{ fontSize: '12px' }}>Tables:</Text>
                      <div style={{ display: 'flex', flexWrap: 'wrap', gap: '4px', marginTop: '4px' }}>
                        {module.tables.map(table => (
                          <Tag key={table} color="blue" style={{ fontSize: '11px' }}>{table}</Tag>
                        ))}
                      </div>
                    </div>
                    <div style={{ marginTop: '8px' }}>
                      <Text type="secondary" style={{ fontSize: '12px' }}>Features:</Text>
                      <div style={{ display: 'flex', flexWrap: 'wrap', gap: '4px', marginTop: '4px' }}>
                        {module.features.map(feature => (
                          <Tag key={feature} style={{ fontSize: '11px' }}>{feature}</Tag>
                        ))}
                      </div>
                    </div>
                    <div style={{ marginTop: '8px' }}>
                      <code style={{ 
                        fontSize: '11px', 
                        backgroundColor: '#f5f5f5', 
                        padding: '2px 8px', 
                        borderRadius: '4px' 
                      }}>
                        {module.apiBase}
                      </code>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </Card>
    ))}
  </div>
);

