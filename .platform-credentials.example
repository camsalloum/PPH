# ProPackHub Platform Configuration for Interplast
# Generated: December 28, 2025

# ============================================================================
# PLATFORM API CREDENTIALS
# ============================================================================
# These credentials allow Interplast to report metrics to the SaaS platform
# 
# SECURITY: Keep these credentials SECRET and secure
# - Never commit to version control
# - Store in environment variables or secure vault
# - Rotate periodically for security
# ============================================================================

PLATFORM_URL=http://localhost:5000
PLATFORM_API_KEY=ppk_REPLACE_ME_WITH_YOUR_API_KEY
PLATFORM_API_SECRET=REPLACE_ME_WITH_YOUR_API_SECRET

# Metrics reporting interval (milliseconds)
# Default: 3600000 (1 hour)
METRICS_REPORT_INTERVAL=3600000

# ============================================================================
# USAGE INSTRUCTIONS
# ============================================================================
# 
# 1. Add these variables to your .env file (DO NOT commit to git)
# 2. The PlatformMetricsReporter service will use these credentials
# 3. To manually test reporting:
#    node -e "const r = require('./server/services/PlatformMetricsReporter'); r.init().then(() => r.reportMetrics())"
# 
# 4. Metrics reported:
#    - active_user_count: Active users in system
#    - total_user_count: Total users
#    - division_count: Number of divisions
#    - storage_used_mb: Database size in MB
#    - monthly_active_users: Users active this month
#    - data_records_count: Count of business records
# 
# ============================================================================
