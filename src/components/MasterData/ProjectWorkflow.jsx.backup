// =============================================================================
// COMPONENT: Project Overview
// =============================================================================
const ProjectOverview = () => (
  <div style={{ padding: '20px' }}>
    {/* Hero Section */}
    <div style={{
      background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
      borderRadius: '16px',
      padding: '32px',
      marginBottom: '24px',
      color: 'white',
    }}>
      <Title level={2} style={{ color: 'white', marginBottom: '8px' }}>
        🏭 FlexPack ERP System
      </Title>
      <Paragraph style={{ color: 'rgba(255,255,255,0.9)', fontSize: '16px', marginBottom: '16px' }}>
        A comprehensive Enterprise Resource Planning system for Flexible Packaging industry.
        Built with React, Node.js, and PostgreSQL following a 32-module architecture.
      </Paragraph>
      <div style={{ display: 'flex', gap: '16px', flexWrap: 'wrap' }}>
        <Tag color="cyan" style={{ padding: '4px 12px', fontSize: '14px' }}>
          React 18+ Frontend
        </Tag>
        <Tag color="green" style={{ padding: '4px 12px', fontSize: '14px' }}>
          Node.js/Express Backend
        </Tag>
        <Tag color="blue" style={{ padding: '4px 12px', fontSize: '14px' }}>
          PostgreSQL Database
        </Tag>
        <Tag color="purple" style={{ padding: '4px 12px', fontSize: '14px' }}>
          JWT Authentication
        </Tag>
      </div>
    </div>

    {/* Progress Overview */}
    <Card title={<><CheckCircleOutlined /> Implementation Progress</>} style={styles.card}>
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '16px' }}>
        {PROJECT_PHASES.map(phase => {
          const implementedCount = phase.modules.filter(m => m.status === 'IMPLEMENTED').length;
          const progress = Math.round((implementedCount / phase.modules.length) * 100);
          return (
            <div key={phase.id} style={{
              padding: '16px',
              borderRadius: '12px',
              backgroundColor: '#fafafa',
              border: `2px solid ${phase.color}20`,
            }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: '8px', marginBottom: '12px' }}>
                <span style={{ color: phase.color, fontSize: '20px' }}>{phase.icon}</span>
                <Text strong>{phase.name}</Text>
              </div>
              <Progress 
                percent={progress} 
                strokeColor={phase.color}
                size="small"
              />
              <Text type="secondary" style={{ fontSize: '12px' }}>
                {implementedCount}/{phase.modules.length} modules
              </Text>
            </div>
          );
        })}
      </div>
    </Card>

    {/* Legend */}
    <Card title={<><BookOutlined /> Status Legend</>} style={styles.card}>
      <div style={{ display: 'flex', gap: '16px', flexWrap: 'wrap' }}>
        {Object.entries(MODULE_STATUS).map(([key, value]) => (
          <div key={key} style={styles.legendItem}>
            <span style={{ color: value.color }}>{value.icon}</span>
            <Tag color={value.color}>{value.label}</Tag>
          </div>
        ))}
      </div>
    </Card>
  </div>
);

