          </Paragraph>
        </div>
        
        <div style={{ padding: '16px', backgroundColor: '#f9f0ff', borderRadius: '8px' }}>
          <Title level={5} style={{ color: '#722ed1' }}>
            <TeamOutlined /> Sales Rep Groups
          </Title>
          <Paragraph style={{ fontSize: '13px' }}>
            Sales reps can be grouped for combined reporting and budget management.
            Groups are stored per division in <code style={{ whiteSpace: 'pre-wrap', wordBreak: 'break-word' }}>sales_rep_groups</code>.
          </Paragraph>
        </div>
      </div>
    </Card>
  </div>
);

// =============================================================================
// COMPONENT: API Reference
// =============================================================================
const APIReference = () => {
  const apiEndpoints = [
    {
      category: 'Authentication',
      color: '#1890ff',
      endpoints: [
        { method: 'POST', path: '/api/auth/login', desc: 'User login with JWT' },
        { method: 'POST', path: '/api/auth/refresh', desc: 'Refresh access token' },
        { method: 'POST', path: '/api/auth/logout', desc: 'Logout and invalidate token' },
      ],
    },
    {
      category: 'AEBF Data',
      color: '#52c41a',
      endpoints: [
        { method: 'GET', path: '/api/aebf/actual', desc: 'Get actual/estimate data' },
        { method: 'GET', path: '/api/aebf/budget', desc: 'Get budget data' },
        { method: 'POST', path: '/api/aebf/save-html-budget', desc: 'Save budget entry' },
        { method: 'POST', path: '/api/aebf/bulk-import', desc: 'Bulk import HTML files' },
        { method: 'POST', path: '/api/aebf/bulk-finalize/:batchId', desc: 'Finalize bulk import' },
        { method: 'GET', path: '/api/aebf/year-summary', desc: 'Get yearly summaries' },
      ],
    },
    {
      category: 'Dashboard & Reports',
      color: '#722ed1',
      endpoints: [
        { method: 'POST', path: '/api/dashboards/customer-universal', desc: 'Customer dashboard data' },
        { method: 'POST', path: '/api/dashboards/amount', desc: 'Amount aggregations' },
        { method: 'GET', path: '/api/sales-reps-universal', desc: 'Get sales reps by division' },
        { method: 'POST', path: '/api/sales-by-country-db', desc: 'Sales by country data' },
      ],
    },
    {
      category: 'Master Data',
      color: '#faad14',
      endpoints: [
        { method: 'GET', path: '/api/fp/master-data/product-pricing', desc: 'Get product pricing' },
        { method: 'POST', path: '/api/fp/master-data/product-pricing-rounded', desc: 'Save pricing' },
        { method: 'GET', path: '/api/fp/master-data/material-percentages', desc: 'Get materials' },
        { method: 'POST', path: '/api/fp/master-data/material-percentages', desc: 'Save materials' },
      ],
    },
  ];

  return (
    <div style={{ padding: '20px' }}>
      <Card title={<><ApiOutlined /> API Reference</>} style={styles.card}>
        <Collapse defaultActiveKey={['0']}>
          {apiEndpoints.map((cat, idx) => (
            <Panel
              key={idx}
              header={
                <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
                  <span style={{
                    width: '12px',
                    height: '12px',
                    borderRadius: '50%',
                    backgroundColor: cat.color,
                  }}></span>
                  <Text strong>{cat.category}</Text>
                  <Badge count={cat.endpoints.length} style={{ backgroundColor: cat.color }} />
                </div>
              }
            >
              <table style={{ width: '100%', borderCollapse: 'collapse' }}>
                <thead>
                  <tr style={{ backgroundColor: '#fafafa' }}>
                    <th style={{ padding: '8px', textAlign: 'left', width: '80px' }}>Method</th>
                    <th style={{ padding: '8px', textAlign: 'left' }}>Endpoint</th>
                    <th style={{ padding: '8px', textAlign: 'left' }}>Description</th>
                  </tr>
                </thead>
                <tbody>
                  {cat.endpoints.map((ep, epIdx) => (
                    <tr key={epIdx}>
                      <td style={{ padding: '8px', borderTop: '1px solid #f0f0f0' }}>
                        <Tag color={ep.method === 'GET' ? 'green' : 'blue'}>{ep.method}</Tag>
                      </td>
                      <td style={{ padding: '8px', borderTop: '1px solid #f0f0f0' }}>
                        <code style={{ fontSize: '12px', backgroundColor: '#f5f5f5', padding: '2px 6px', borderRadius: '4px' }}>
                          {ep.path}
                        </code>
                      </td>
                      <td style={{ padding: '8px', borderTop: '1px solid #f0f0f0', color: '#666' }}>
                        {ep.desc}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </Panel>
          ))}
        </Collapse>
      </Card>
    </div>
  );
};

// =============================================================================
// COMPONENT: ERP Flow Diagram - Clean Card-Based with Progress Tracking
// Uses ERP_MODULES and PHASES defined at top of file (single source of truth)
// =============================================================================

const ERPFlowDiagram = () => {
  const [lastUpdated, setLastUpdated] = useState(new Date());

  // Calculate progress statistics
  const stats = {
    total: ERP_MODULES.length,
    done: ERP_MODULES.filter(m => m.status === 'done').length,
    partial: ERP_MODULES.filter(m => m.status === 'partial').length,
    planned: ERP_MODULES.filter(m => m.status === 'planned').length,
  };
  const progressPercent = Math.round(((stats.done + stats.partial * 0.5) / stats.total) * 100);

  const handleRefresh = () => {
    setLastUpdated(new Date());
  };

  // Module Card Component
  const ModuleCard = ({ module }) => {
    const phase = PHASES.find(p => p.id === module.phase);
    const statusConfig = STATUS_CONFIG[module.status];
    
    return (
      <div style={{
        display: 'flex',
        alignItems: 'center',
        padding: '12px 16px',
        backgroundColor: statusConfig.bgColor,
        borderRadius: '8px',
        border: `2px solid ${module.status === 'done' ? statusConfig.color : '#e8e8e8'}`,
        marginBottom: '8px',
        transition: 'all 0.3s ease',
        position: 'relative',
        overflow: 'hidden',
      }}>
        {/* Status indicator */}
        <div style={{
          width: '32px',
          height: '32px',
          borderRadius: '50%',
          backgroundColor: statusConfig.color,
          color: 'white',
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
          fontWeight: 'bold',
          fontSize: '16px',
          marginRight: '12px',
          flexShrink: 0,
        }}>
          {statusConfig.icon}
        </div>
        
        {/* Module info */}
        <div style={{ flex: 1, minWidth: 0 }}>
          <div style={{ 
            display: 'flex', 
            alignItems: 'center', 
            gap: '8px',
            marginBottom: '2px',
          }}>
            <span style={{ fontSize: '16px' }}>{module.icon}</span>
            <Text strong style={{ 
              fontSize: '13px',
              color: module.status === 'done' ? '#52c41a' : '#333',
            }}>
              Module {module.id}
            </Text>
            {module.critical && (
              <Tag color="red" style={{ fontSize: '10px', padding: '0 4px', margin: 0 }}>
                CRITICAL
              </Tag>
            )}
          </div>
          <Text style={{ 
            fontSize: '12px', 
            color: '#666',
            display: 'block',
            whiteSpace: 'nowrap',
            overflow: 'hidden',
            textOverflow: 'ellipsis',
          }}>
            {module.name}
          </Text>
        </div>

        {/* Status badge */}
        <Tag 
          color={statusConfig.color} 
          style={{ 
            margin: 0, 
            fontSize: '11px',
            flexShrink: 0,
          }}
        >
          {statusConfig.label}
        </Tag>
      </div>
    );
  };

  return (
    <div style={{ padding: '20px' }}>
      {/* Header with Progress */}
      <Card style={{ marginBottom: '24px', borderRadius: '12px' }}>
        <div style={{
          background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
          borderRadius: '8px',
          padding: '24px',
          marginBottom: '20px',
          color: 'white',
        }}>
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', flexWrap: 'wrap', gap: '16px' }}>
            <div>
              <Title level={3} style={{ color: 'white', marginBottom: '8px' }}>
                🏭 FlexPack ERP - 32 Module Roadmap
              </Title>
              <Paragraph style={{ color: 'rgba(255,255,255,0.9)', marginBottom: 0 }}>
                Complete system from Customer Contact → Product Delivery
              </Paragraph>
            </div>
            <div style={{ textAlign: 'right' }}>
              <div style={{ fontSize: '36px', fontWeight: 'bold' }}>{progressPercent}%</div>
              <div style={{ fontSize: '12px', opacity: 0.9 }}>Overall Progress</div>
            </div>
          </div>
        </div>

        {/* Stats Row */}
        <div style={{ display: 'flex', gap: '16px', flexWrap: 'wrap', marginBottom: '16px' }}>
          <div style={{ 
            flex: '1', 
            minWidth: '120px',
            padding: '16px', 
            backgroundColor: '#f6ffed', 
            borderRadius: '8px',
            textAlign: 'center',
            border: '2px solid #52c41a',
          }}>
            <div style={{ fontSize: '28px', fontWeight: 'bold', color: '#52c41a' }}>{stats.done}</div>
            <div style={{ fontSize: '12px', color: '#666' }}>✓ Completed</div>
          </div>
          <div style={{ 
            flex: '1', 
            minWidth: '120px',
            padding: '16px', 
            backgroundColor: '#e6f7ff', 
            borderRadius: '8px',
            textAlign: 'center',
            border: '2px solid #1890ff',
          }}>
            <div style={{ fontSize: '28px', fontWeight: 'bold', color: '#1890ff' }}>{stats.partial}</div>
            <div style={{ fontSize: '12px', color: '#666' }}>◐ In Progress</div>
          </div>
          <div style={{ 
            flex: '1', 
            minWidth: '120px',
            padding: '16px', 
            backgroundColor: '#fafafa', 
            borderRadius: '8px',
            textAlign: 'center',
            border: '2px solid #d9d9d9',
          }}>
            <div style={{ fontSize: '28px', fontWeight: 'bold', color: '#8c8c8c' }}>{stats.planned}</div>
            <div style={{ fontSize: '12px', color: '#666' }}>○ Planned</div>
          </div>
          <div style={{ 
            flex: '1', 
            minWidth: '120px',
            padding: '16px', 
            backgroundColor: '#fff7e6', 
            borderRadius: '8px',
            textAlign: 'center',
            border: '2px solid #faad14',
          }}>
            <div style={{ fontSize: '28px', fontWeight: 'bold', color: '#faad14' }}>{stats.total}</div>
            <div style={{ fontSize: '12px', color: '#666' }}>Total Modules</div>
          </div>
        </div>

        {/* Progress Bar */}
        <Progress 
          percent={progressPercent} 
          strokeColor={{
            '0%': '#52c41a',
            '100%': '#1890ff',
          }}
          trailColor="#f0f0f0"
          strokeWidth={12}
          style={{ marginBottom: '8px' }}
        />
        
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
          <Text type="secondary" style={{ fontSize: '12px' }}>
            Last updated: {lastUpdated.toLocaleString()}
          </Text>
          <button
            onClick={handleRefresh}
            style={{
              padding: '4px 12px',
              backgroundColor: '#1890ff',
              color: 'white',
              border: 'none',
              borderRadius: '4px',
              cursor: 'pointer',
              fontSize: '12px',
            }}
          >
            <SyncOutlined /> Refresh
          </button>
        </div>
      </Card>

      {/* Phases Grid */}
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(350px, 1fr))', gap: '20px' }}>
        {PHASES.map(phase => {
          const phaseModules = ERP_MODULES.filter(m => m.phase === phase.id);
          const phaseDone = phaseModules.filter(m => m.status === 'done').length;
          const phaseProgress = Math.round((phaseDone / phaseModules.length) * 100);
          
          return (
            <Card 
              key={phase.id}
              style={{ 
                borderRadius: '12px',
                borderTop: `4px solid ${phase.color}`,
              }}
              title={
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                  <span>
                    <span style={{ 
                      backgroundColor: phase.color, 
                      color: 'white', 
                      padding: '2px 8px', 
                      borderRadius: '4px',
                      fontSize: '12px',
                      marginRight: '8px',
                    }}>
                      Phase {phase.id}
                    </span>
                    {phase.name}
                  </span>
                  <Tag color={phaseProgress === 100 ? 'green' : 'default'}>
                    {phaseDone}/{phaseModules.length}
                  </Tag>
                </div>
              }
              extra={<Text type="secondary" style={{ fontSize: '11px' }}>Weeks {phase.weeks}</Text>}
            >
              <Progress 
                percent={phaseProgress} 
                size="small" 
                strokeColor={phase.color}
                style={{ marginBottom: '12px' }}
              />
              
              {phaseModules.map(module => (
                <ModuleCard key={module.id} module={module} />
              ))}
            </Card>
          );
        })}
      </div>

      {/* Flow Summary */}
      <Card 
        title={<><ArrowRightOutlined /> Process Flow Summary</>}
        style={{ marginTop: '24px', borderRadius: '12px' }}
      >
        <div style={{ 
          display: 'flex', 
          alignItems: 'center', 
          justifyContent: 'center',
          flexWrap: 'wrap',
          gap: '8px',
          padding: '20px',
          backgroundColor: '#fafafa',
          borderRadius: '8px',
        }}>
          {[
            { label: 'Customer Contact', color: '#52c41a', done: true },
            { label: 'Lead/Inquiry', color: '#52c41a', done: false },
            { label: 'Quote', color: '#52c41a', done: true },
            { label: 'Order', color: '#faad14', done: false },
            { label: 'Design', color: '#faad14', done: false },
            { label: 'Production', color: '#722ed1', done: false },
            { label: 'QC', color: '#13c2c2', done: false },
            { label: 'Delivery', color: '#f5222d', done: false },
            { label: 'Invoice', color: '#f5222d', done: false },
          ].map((step, idx, arr) => (
            <React.Fragment key={step.label}>
              <div style={{
                padding: '8px 16px',
                backgroundColor: step.done ? '#f6ffed' : '#fff',
                border: `2px solid ${step.done ? '#52c41a' : '#e8e8e8'}`,
                borderRadius: '20px',
                display: 'flex',
                alignItems: 'center',
                gap: '6px',
              }}>
                {step.done && <span style={{ color: '#52c41a', fontWeight: 'bold' }}>✓</span>}
                <span style={{ fontSize: '12px', fontWeight: '500' }}>{step.label}</span>
              </div>
              {idx < arr.length - 1 && (
                <ArrowRightOutlined style={{ color: '#d9d9d9' }} />
              )}
            </React.Fragment>
          ))}
        </div>
      </Card>
    </div>
  );
};

// =============================================================================
// MAIN COMPONENT
// =============================================================================
const ProjectWorkflow = () => {
  const [activeTab, setActiveTab] = useState('overview');

  const tabItems = [
    {
      key: 'overview',
      label: (
        <span>
          <DashboardOutlined /> Overview
        </span>
      ),
      children: <ProjectOverview />,
    },
    {
      key: 'modules',
      label: (
        <span>
          <ClusterOutlined /> Modules
        </span>
      ),
      children: <ModuleArchitecture />,
    },
    {
      key: 'database',
      label: (
        <span>
          <DatabaseOutlined /> Database
        </span>
      ),
      children: <DatabaseSchema />,
    },
    {
      key: 'flows',
      label: (
        <span>
          <SyncOutlined /> Data Flows
        </span>
      ),
      children: <DataFlows />,
    },
    {
      key: 'architecture',
      label: (
        <span>
          <NodeIndexOutlined /> Architecture
        </span>
      ),
      children: <SystemFlow />,
    },
    {
      key: 'api',
      label: (
        <span>
          <ApiOutlined /> API Reference
        </span>
      ),
      children: <APIReference />,
    },
    {
      key: 'erp-flow',
      label: (
        <span>
          <PartitionOutlined /> ERP Flow
        </span>
      ),
      children: <ERPFlowDiagram />,
    },
  ];

  return (
    <div style={styles.container}>
      <Tabs
        activeKey={activeTab}
        onChange={setActiveTab}
        type="card"
        size="large"
        items={tabItems}
        style={{
          backgroundColor: 'white',
          padding: '16px',
          borderRadius: '12px',
          boxShadow: '0 2px 8px rgba(0,0,0,0.08)',
        }}
      />
    </div>
  );
};

export default ProjectWorkflow;
