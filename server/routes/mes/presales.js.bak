// PATCH /qc/templates/:id — update template (admin/manager)
router.patch('/qc/templates/:id', authenticate, async (req, res) => {
  if (!isAdminOrMgmt(req.user)) {
    return res.status(403).json({ success: false, error: 'Management role required' });
  }
  try {
    const { id } = req.params;
    const { name, product_group, test_category, parameters, notes, is_active } = req.body;
    const result = await pool.query(
      `UPDATE mes_qc_templates
       SET name          = COALESCE($1, name),
           product_group = COALESCE($2, product_group),
           test_category = COALESCE($3, test_category),
           parameters    = COALESCE($4::jsonb, parameters),
           notes         = COALESCE($5, notes),
           is_active     = COALESCE($6, is_active),
           updated_at    = NOW()
       WHERE id = $7
       RETURNING *`,
      [name || null, product_group || null, test_category || null,
       parameters ? JSON.stringify(parameters) : null,
       notes || null, is_active != null ? is_active : null, id]
    );
    if (result.rows.length === 0) return res.status(404).json({ success: false, error: 'Template not found' });
    res.json({ success: true, data: result.rows[0] });
  } catch (err) {
    logger.error('MES: error updating QC template', err);
    res.status(500).json({ success: false, error: 'Internal server error' });
  }
});

// DELETE /qc/templates/:id — soft-delete template (admin only)
router.delete('/qc/templates/:id', authenticate, async (req, res) => {
  if (!isAdminOrMgmt(req.user)) {
    return res.status(403).json({ success: false, error: 'Management role required' });
  }
  try {
    const { id } = req.params;
    await pool.query(`UPDATE mes_qc_templates SET is_active = FALSE, updated_at = NOW() WHERE id = $1`, [id]);
    res.json({ success: true });
  } catch (err) {
    logger.error('MES: error deleting QC template', err);
    res.status(500).json({ success: false, error: 'Internal server error' });
  }
});

// ═════════════════════════════════════════════════════════════════════════════
// G-005: CSE DISCUSSION THREAD (COMMENTS)
// ═════════════════════════════════════════════════════════════════════════════

// GET /cse/:id/comments — fetch discussion thread
router.get('/cse/:id/comments', authenticate, async (req, res) => {
  try {
    const cseId = parseInt(req.params.id, 10);
    if (!Number.isInteger(cseId) || cseId <= 0) {
      return res.status(400).json({ success: false, error: 'Invalid CSE id' });
    }
    const result = await pool.query(
      `SELECT c.*
       FROM mes_cse_comments c
       WHERE c.cse_id = $1
         AND ($2 OR c.is_internal = FALSE)
       ORDER BY c.created_at ASC`,
      [cseId, isAdminOrMgmt(req.user)]
    );
    res.json({ success: true, data: result.rows });
  } catch (err) {
    logger.error('MES: error fetching CSE comments', err);
    res.status(500).json({ success: false, error: 'Internal server error' });
  }
});

// POST /cse/:id/comments — add a comment
router.post('/cse/:id/comments', authenticate, async (req, res) => {
  try {
    const cseId = parseInt(req.params.id, 10);
    if (!Number.isInteger(cseId) || cseId <= 0) {
      return res.status(400).json({ success: false, error: 'Invalid CSE id' });
    }
    const { comment, is_internal, parent_comment_id } = req.body;
    if (!comment || !comment.trim()) {
      return res.status(400).json({ success: false, error: 'comment is required' });
    }
    // Only admins/managers can post internal comments
    const internal = is_internal === true && isAdminOrMgmt(req.user);

    const result = await pool.query(
      `INSERT INTO mes_cse_comments (cse_id, user_id, user_name, user_role, comment, is_internal, parent_comment_id)
       VALUES ($1, $2, $3, $4, $5, $6, $7)
       RETURNING *`,
      [cseId, req.user?.id || null, actorName(req.user), req.user?.role || null,
       comment.trim(), internal, parent_comment_id || null]
    );
    res.status(201).json({ success: true, data: result.rows[0] });
  } catch (err) {
    logger.error('MES: error adding CSE comment', err);
    res.status(500).json({ success: false, error: 'Internal server error' });
  }
});

// DELETE /cse/:id/comments/:commentId — delete own comment (or admin)
router.delete('/cse/:id/comments/:commentId', authenticate, async (req, res) => {
  try {
    const { commentId } = req.params;
    const row = await pool.query(`SELECT * FROM mes_cse_comments WHERE id = $1`, [commentId]);
    if (row.rows.length === 0) return res.status(404).json({ success: false, error: 'Comment not found' });
    const c = row.rows[0];
    if (c.user_id !== req.user?.id && !isAdminOrMgmt(req.user)) {
      return res.status(403).json({ success: false, error: 'Cannot delete another user\'s comment' });
    }
    await pool.query(`DELETE FROM mes_cse_comments WHERE id = $1`, [commentId]);
    res.json({ success: true });
  } catch (err) {
    logger.error('MES: error deleting CSE comment', err);
    res.status(500).json({ success: false, error: 'Internal server error' });
  }
});

