// Status configurations
const STATUS_CONFIG = {
  done: { label: 'Completed', color: '#52c41a', icon: '✓', bgColor: '#f6ffed' },
  partial: { label: 'In Progress', color: '#1890ff', icon: '◐', bgColor: '#e6f7ff' },
