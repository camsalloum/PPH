# ================================
# IPD 10-12 Server Configuration
# ================================

# Environment
NODE_ENV=development

# Server
PORT=3001

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=fp_database
AUTH_DB_NAME=ip_auth_database

# Database Pool
DB_POOL_MAX=20

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_ACCESS_EXPIRY=3650d
JWT_REFRESH_EXPIRY=3650d

# CORS
CORS_ORIGIN=http://localhost:3000

# ── Email (SMTP) ──
# Set SMTP_DEV_MODE=true for local testing (uses Ethereal fake SMTP, no real emails).
# Preview URLs are logged in the console so you can view each email in a browser.
SMTP_DEV_MODE=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@propackhub.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM=ProPack Hub <notifications@propackhub.com>

# QC Notification Recipients
QC_LAB_EMAIL=qclab@yourcompany.com
QC_MANAGER_EMAIL=qcmanager@yourcompany.com

# App URL (used in email links)
APP_URL=http://localhost:3000

# ── Outlook / Microsoft Graph (Pre-Azure Groundwork) ──
# Generate encryption key:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OUTLOOK_TOKEN_ENCRYPTION_KEY=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=common
OUTLOOK_REDIRECT_URI=https://your-crm.com/api/auth/outlook/callback

# Optional webhook migration (Phase 3b)
OUTLOOK_WEBHOOK_NOTIFICATION_URL=
OUTLOOK_WEBHOOK_CLIENT_STATE=